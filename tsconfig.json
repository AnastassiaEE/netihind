{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "incremental": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/components/*": ["app/components/*"],
      "@/layouts/*": ["app/layouts/*"],
      "@/data/*": ["app/data/*"],
      "@/hooks/*": ["app/hooks/*"],
      "@/utils/*": ["app/utils/*"],
      "@/markdown/*": ["app/markdown/*"],
      "@/app/*": ["app/*"],
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx",
    "app/blog/[postId]/page.tsx"
  ],
  "exclude": ["node_modules"]
}
